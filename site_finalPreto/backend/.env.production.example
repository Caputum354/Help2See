# ─────────────────────────────────────────────────────────────────
# TEMPLATE de variáveis de PRODUÇÃO (Railway) — SEM valores reais.
# NÃO coloque segredos aqui. Copie estas CHAVES para o painel do Railway
# (Service → Variables) e preencha os VALORES lá. Este arquivo pode ir para
# o git; o .env real (com segredos) NUNCA vai (está no .gitignore).
# ─────────────────────────────────────────────────────────────────

# ── ElevenLabs (TTS) — chave fica só no servidor, nunca no navegador ──
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
ELEVENLABS_AUTO_RESOLVE_VOICE=true

# ── Rede ──────────────────────────────────────────────────────────
# No Railway o start command já usa --host 0.0.0.0 --port $PORT (Procfile),
# então HOST/PORT abaixo não são usados pelo web server.
HOST=0.0.0.0
PORT=8000

# Domínios do front-end (Vercel) autorizados a chamar a API (CORS).
# Troque pelo seu domínio real da Vercel.
CORS_ORIGINS=https://SEU-SITE.vercel.app

# ── MongoDB Atlas (analytics) ─────────────────────────────────────
# String de conexão do cluster Atlas (Database → Connect → Drivers).
MONGODB_URI=mongodb+srv://USUARIO:SENHA@cluster.xxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=help2see

# ── MySQL (Railway) ───────────────────────────────────────────────
# Use as variáveis internas do plugin MySQL do Railway (rede privada).
# No Railway você pode referenciar: ${{MySQL.MYSQLHOST}}, etc.
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DB=railway

# ── Segredos HMAC / sessão — GERE NOVOS para produção ─────────────
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
VISITOR_HASH_SECRET=

EVENTS_TTL_SECONDS=7776000
COLLECT_MAX_BATCH=200
# Atrás do proxy do Railway, confie no X-Forwarded-For para IP real.
TRUST_PROXY=true
# Uma única instância pode rodar o job de agregação in-process.
SCHEDULER_ENABLED=true

# ── Autenticação ──────────────────────────────────────────────────
AUTH_PASSWORD_MIN_LEN=6
SESSION_TTL_SECONDS=2592000
# Base pública do site (Vercel) — usada no link de confirmação de e-mail.
FRONTEND_BASE_URL=https://SEU-SITE.vercel.app

# ── Recuperação de senha (OTP) ────────────────────────────────────
PASSWORD_RESET_CODE_TTL_SECONDS=900
PASSWORD_RESET_MAX_ATTEMPTS=5
RESET_RATE_MAX_HITS=5
RESET_RATE_WINDOW_SECONDS=300

# ── SMTP (envio de e-mail) ────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_FROM_NAME=Help2See
SMTP_STARTTLS=true
SMTP_SSL=false

# ── Mercado Pago (assinatura) ─────────────────────────────────────
# Em produção use as credenciais de PRODUÇÃO (prefixo APP_USR-), não TEST-.
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=
# URL pública DESTA API no Railway (para o webhook do Mercado Pago).
API_PUBLIC_URL=https://SEU-BACKEND.up.railway.app
SUBSCRIPTION_PRICE_MONTHLY_CENTS=4900
SUBSCRIPTION_PRICE_ANNUAL_CENTS=46800
