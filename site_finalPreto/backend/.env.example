# Help2See backend — copy to .env and fill in.
# NEVER commit the real .env. The key stays on the server only.

# Get your key at https://elevenlabs.io  (Developers → API Keys)
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here

# Leave blank to auto-resolve a voice the account owns (recommended).
# To pin a voice, run GET /api/voices and use one of the returned IDs.
# Avoid legacy "premade" IDs (e.g. Rachel 21m00Tcm4TlvDq8ikWAM): they are
# deprecated and return HTTP 402 on the Free tier.
ELEVENLABS_VOICE_ID=

ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
ELEVENLABS_AUTO_RESOLVE_VOICE=true

HOST=127.0.0.1
PORT=8000

# Comma-separated list of origins allowed to call the API (your site).
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:8080,http://127.0.0.1:8080

# ── Pipeline de analytics ───────────────────────────────────────
# MongoDB: eventos brutos (time-series, com expiração automática) + agregados diários.
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB=help2see

# MySQL: guarda o mapeamento público site_key → (site_id, org_id).
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DB=help2see

# Segredo do pseudônimo de visitante com rotação diária (HMAC). TROQUE EM PRODUÇÃO.
# Gere um, ex.:  python -c "import secrets; print(secrets.token_hex(32))"
VISITOR_HASH_SECRET=dev-only-change-me

# Eventos brutos expiram após este número de segundos (padrão 90 dias).
EVENTS_TTL_SECONDS=7776000

# TTL das coleções de telemetria por concern (segundos, padrão 90 dias).
ERRORS_TTL_SECONDS=7776000
PERFORMANCE_TTL_SECONDS=7776000
SESSIONS_TTL_SECONDS=7776000
APP_ACTIONS_TTL_SECONDS=7776000

# Liga/desliga toda a telemetria de Mongo (writes fire-and-forget, nunca bloqueiam).
TELEMETRY_ENABLED=true
# Amostragem (0..1) do middleware de tempo de requisição da API (0 desliga).
API_TELEMETRY_SAMPLE_RATE=0.1

# Máximo de eventos aceitos por lote no /collect.
COLLECT_MAX_BATCH=200

# Confiar no X-Forwarded-For para o IP do cliente (só atrás de um proxy que você controla).
TRUST_PROXY=false

# Roda o job de agregação horário in-process (senão use cron / python -m jobs.aggregate).
SCHEDULER_ENABLED=false

# ── Autenticação ────────────────────────────────────────────────
# Tamanho mínimo de senha (alinhado ao front-end).
AUTH_PASSWORD_MIN_LEN=6
# Validade da sessão de login (segundos, padrão 30 dias).
SESSION_TTL_SECONDS=2592000

# ── Recuperação de senha por e-mail (código OTP) ────────────────
# Validade do código de 6 dígitos (segundos, padrão 15 min).
PASSWORD_RESET_CODE_TTL_SECONDS=900
# Tentativas de verificação antes de invalidar o código (anti força-bruta).
PASSWORD_RESET_MAX_ATTEMPTS=5
# Rate limit de /forgot e /verify-code: máx. requisições por janela, por chave.
RESET_RATE_MAX_HITS=5
RESET_RATE_WINDOW_SECONDS=300

# ── SMTP (envio do código de recuperação por e-mail) ────────────
# Ex. Gmail: SMTP_HOST=smtp.gmail.com SMTP_PORT=587 SMTP_STARTTLS=true
#   (use uma "Senha de app": https://myaccount.google.com/apppasswords)
# Deixe em branco em dev: o backend devolve o código na resposta de /forgot
# (campo dev_code) para teste manual.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
# Remetente exibido; se vazio, usa SMTP_USER.
SMTP_FROM=
SMTP_FROM_NAME=Help2See
SMTP_STARTTLS=true
SMTP_SSL=false

# ── Base pública do site (back_urls do checkout + link de confirmação) ──
# Aponte para a raiz onde os arquivos são servidos. No Live Server do VS Code
# (servindo a pasta do projeto), inclua /site_finalPreto.
FRONTEND_BASE_URL=http://127.0.0.1:5500/site_finalPreto

# ── Assinatura do plano Profissional (Mercado Pago) ─────────────
# https://www.mercadopago.com.br/developers (Credenciais). Em dev use o token
# de TESTE (prefixo TEST-). Em branco => checkout desabilitado (rota 503).
MERCADOPAGO_ACCESS_TOKEN=TEST-your-mercadopago-access-token
MERCADOPAGO_WEBHOOK_SECRET=your-mercadopago-webhook-secret
# Preço em centavos (decidido no servidor): mensal R$49,00; anual R$468,00.
SUBSCRIPTION_PRICE_MONTHLY_CENTS=4900
SUBSCRIPTION_PRICE_ANNUAL_CENTS=46800
